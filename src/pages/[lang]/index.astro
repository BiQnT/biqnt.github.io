---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SocialLinks from '../../components/SocialLinks.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
import { locales } from '../../i18n/utils';

export function getStaticPaths() {
  return locales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
---

<BaseLayout title={`${t('home.name')} | ${t('home.title')}`}>
  <div class="flex flex-col items-center text-center py-12 sm:py-20">
    <!-- Profile image: put your photo at public/images/profile.jpg -->
    <div class="w-28 h-28 rounded-none overflow-hidden pixel-border mb-6 bg-[var(--color-primary)]/10 flex items-center justify-center" style="image-rendering: pixelated;">
      <img
        src="/images/profile.jpg"
        alt="Donghyun Ahn"
        class="w-full h-full object-cover"
        onerror="this.style.display='none'; this.parentElement.innerHTML='<span class=\'text-4xl\'>👨‍💻</span>';"
      />
    </div>

    <p class="font-pixel text-[var(--color-on-surface-muted)] text-sm mb-2 pixel-cursor">{t('home.greeting')}</p>
    <h1 class="font-pixel text-2xl sm:text-3xl mb-2">
      <span class="text-[var(--color-primary)]">{t('home.name')}</span>
    </h1>
    <p class="text-[var(--color-on-surface-muted)] text-lg mb-6 max-w-md">
      {t('home.title')}
    </p>
    <hr class="pixel-divider w-24 mx-auto mb-6" />
    <p class="text-[var(--color-on-surface)] max-w-lg mb-8 leading-relaxed">
      {t('home.intro')}
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-wrap justify-center gap-3 mb-8">
      <a
        href={getLocalizedPath('/experience', lang)}
        class="px-5 py-2.5 rounded-none pixel-border bg-[var(--color-primary)] text-[var(--color-on-primary)] font-medium hover:bg-[var(--color-primary-hover)] transition-colors"
      >
        {t('nav.experience')}
      </a>
      <a
        href={getLocalizedPath('/research', lang)}
        class="px-5 py-2.5 rounded-none pixel-border bg-[var(--color-surface-alt)] text-[var(--color-on-surface)] font-medium hover:bg-[var(--color-primary)]/10 hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] transition-colors"
      >
        {t('home.cta.research')}
      </a>
    </div>

    <SocialLinks />
  </div>

</BaseLayout>
