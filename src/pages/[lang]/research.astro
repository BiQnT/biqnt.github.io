---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
import { locales } from '../../i18n/utils';
import data from '../../data/research.json';

export function getStaticPaths() {
  return locales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
const projects = data[lang];
---

<BaseLayout title={`${t('research.title')} | ${t('home.name')}`}>
  <h1 class="font-pixel text-3xl font-bold mb-2">{t('research.title')}</h1>
  <p class="text-[var(--color-on-surface-muted)] mb-8">{t('research.description')}</p>

  <div class="flex flex-col gap-6">
    {projects.map((project: { title: string; organization: string; period: string; description: string; tags: string[]; link?: string; status: string }) => {
      const isLinked = Boolean(project.link);
      const Tag = isLinked ? 'a' : 'article';
      return (
        <Tag
          href={isLinked ? project.link : undefined}
          target={isLinked ? '_blank' : undefined}
          rel={isLinked ? 'noopener noreferrer' : undefined}
          aria-label={isLinked ? `${project.title} — ${t('research.viewPaper')}` : undefined}
          class:list={[
            'block pixel-border rounded-none p-5 bg-[var(--color-surface-alt)] transition-colors',
            isLinked ? 'group cursor-pointer hover:border-[var(--color-accent)]' : 'hover:border-[var(--color-primary)]'
          ]}
        >
          <div class="flex items-start justify-between gap-4 mb-2">
            <h2 class:list={['text-lg font-semibold', isLinked ? 'group-hover:text-[var(--color-accent)] transition-colors' : '']}>{project.title}</h2>
            <span class:list={[
              'px-2 py-0.5 text-xs rounded-none border font-medium shrink-0',
              project.status === '진행 중' || project.status === 'In Progress'
                ? 'border-[var(--color-status-active)] text-[var(--color-status-active)] bg-[var(--color-status-active)]/10'
                : 'border-[var(--color-status-inactive)] text-[var(--color-status-inactive)] bg-[var(--color-status-inactive)]/10'
            ]}>
              {project.status}
            </span>
          </div>
          <p class="text-sm text-[var(--color-primary)] font-medium mb-1">{project.organization}</p>
          <p class="text-xs text-[var(--color-on-surface-muted)] mb-3">{project.period}</p>
          <p class="text-sm text-[var(--color-on-surface-muted)] mb-3 whitespace-pre-line leading-relaxed">{project.description}</p>
          <div class="flex flex-wrap gap-2">
            {project.tags.map((tag: string) => (
              <span class="px-2 py-0.5 text-xs rounded-none border border-[var(--color-primary)]/30 bg-[var(--color-primary)]/10 text-[var(--color-primary)] font-medium">
                {tag}
              </span>
            ))}
          </div>
          {isLinked && (
            <span class="inline-flex items-center gap-1 mt-4 text-sm font-medium text-[var(--color-accent)] group-hover:underline">
              {t('research.viewPaper')}
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </span>
          )}
        </Tag>
      );
    })}
  </div>
</BaseLayout>
