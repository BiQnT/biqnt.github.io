---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';
import { locales } from '../../i18n/utils';
import projects from '../../data/projects.json';

export function getStaticPaths() {
  return locales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
const featuredProjects = projects[lang];
---

<BaseLayout title={`${t('github.title')} | ${t('home.name')}`}>
  <h1 class="font-pixel text-3xl font-bold mb-8 pixel-cursor">{t('github.title')}</h1>

  <!-- Featured Projects (manually added) -->
  {featuredProjects.length > 0 && (
    <section class="mb-12">
      <h2 class="font-pixel text-xl mb-6 text-[var(--color-primary)]">{'> '}{t('github.featured')}</h2>
      <div class="flex flex-col gap-4">
        {featuredProjects.map((project: { title: string; description: string; tags: string[]; link: string; status: string }) => (
          <a href={project.link} target="_blank" rel="noopener noreferrer" class="block pixel-border rounded-none p-5 bg-[var(--color-surface-alt)] hover:border-[var(--color-primary)] transition-colors">
            <div class="flex items-start justify-between gap-4 mb-2">
              <h3 class="font-semibold text-lg">{project.title}</h3>
              <span class:list={[
                'pixel-tag shrink-0',
                project.status === '진행 중' || project.status === 'In Progress'
                  ? 'border-green-500 text-green-600 dark:text-green-400'
                  : ''
              ]}>
                {project.status}
              </span>
            </div>
            <p class="text-sm text-[var(--color-on-surface-muted)] mb-3">{project.description}</p>
            <div class="flex flex-wrap gap-2">
              {project.tags.map((tag: string) => (
                <span class="pixel-tag">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <hr class="pixel-divider my-10" />

  <!-- GitHub Repos (auto-fetched) -->
  <section>
    <h2 class="font-pixel text-xl mb-6 text-[var(--color-primary)]">{'> '}{t('github.repos')}</h2>
    <div id="github-repos" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <p id="repos-loading" class="col-span-full text-center text-[var(--color-on-surface-muted)] py-8 font-pixel text-sm">
        {t('github.loading')}
      </p>
    </div>
  </section>

  <div class="mt-8 text-center">
    <a
      href="https://github.com/biqnt"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 pixel-border px-4 py-2 text-sm font-pixel hover:bg-[var(--color-primary)] hover:text-[var(--color-on-primary)] transition-colors"
    >
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
      {t('github.viewOn')}
    </a>
  </div>
</BaseLayout>

<script is:inline>
(function() {
  const CACHE_KEY = 'github_repos_cache';
  const CACHE_TTL = 3600000;

  function getCachedRepos() {
    try {
      const cached = localStorage.getItem(CACHE_KEY);
      if (!cached) return null;
      const { data, timestamp } = JSON.parse(cached);
      if (Date.now() - timestamp > CACHE_TTL) return null;
      return data;
    } catch { return null; }
  }

  function cacheRepos(data) {
    try {
      localStorage.setItem(CACHE_KEY, JSON.stringify({ data, timestamp: Date.now() }));
    } catch {}
  }

  function renderRepos(repos) {
    const container = document.getElementById('github-repos');
    const loading = document.getElementById('repos-loading');
    if (loading) loading.remove();
    if (!container) return;

    const langColors = {
      'Python': '#3572A5', 'JavaScript': '#f1e05a', 'TypeScript': '#3178c6',
      'C++': '#f34b7d', 'Verilog': '#b2b7f8', 'HTML': '#e34c26',
      'CSS': '#563d7c', 'Rust': '#dea584', 'Go': '#00ADD8',
    };

    repos
      .filter(r => !r.fork)
      .sort((a, b) => b.stargazers_count - a.stargazers_count)
      .slice(0, 12)
      .forEach(repo => {
        const card = document.createElement('a');
        card.href = repo.html_url;
        card.target = '_blank';
        card.rel = 'noopener noreferrer';
        card.className = 'block p-4 bg-[var(--color-surface-alt)] border-2 border-[var(--color-border)] hover:border-[var(--color-primary)] transition-colors';
        card.style.boxShadow = '2px 2px 0 0 var(--color-border)';
        card.innerHTML = `
          <h3 class="font-semibold text-sm mb-1 font-mono text-[var(--color-on-surface)]">${repo.name}</h3>
          <p class="text-xs text-[var(--color-on-surface-muted)] line-clamp-2 mb-3">${repo.description || ''}</p>
          <div class="flex items-center gap-3 text-xs text-[var(--color-on-surface-muted)]">
            ${repo.language ? `<span class="flex items-center gap-1"><span class="w-2.5 h-2.5" style="background:${langColors[repo.language] || '#888'}"></span>${repo.language}</span>` : ''}
            ${repo.stargazers_count > 0 ? `<span>★ ${repo.stargazers_count}</span>` : ''}
          </div>
        `;
        container.appendChild(card);
      });
  }

  function showError() {
    const loading = document.getElementById('repos-loading');
    if (loading) loading.textContent = 'Failed to load repositories.';
  }

  const cached = getCachedRepos();
  if (cached) {
    renderRepos(cached);
  } else {
    fetch('https://api.github.com/users/biqnt/repos?per_page=30&sort=updated')
      .then(r => { if (!r.ok) throw new Error(); return r.json(); })
      .then(data => { cacheRepos(data); renderRepos(data); })
      .catch(showError);
  }
})();
</script>
