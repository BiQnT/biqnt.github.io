---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Page Not Found">
  <div class="flex flex-col items-center justify-center py-20 text-center">
    <div class="text-6xl mb-4" style="image-rendering: pixelated;">🔍</div>
    <h1 class="text-4xl font-bold mb-4">404</h1>
    <p class="text-[var(--color-on-surface-muted)] mb-6">Page not found / 페이지를 찾을 수 없습니다</p>
    <div class="flex gap-3">
      <a href="/ko/" class="px-4 py-2 rounded-lg bg-[var(--color-primary)] text-[var(--color-on-primary)] font-medium hover:bg-[var(--color-primary-hover)] transition-colors">
        홈으로
      </a>
      <a href="/en/" class="px-4 py-2 rounded-lg border border-[var(--color-border)] font-medium hover:bg-[var(--color-surface-alt)] transition-colors">
        Go Home
      </a>
    </div>
  </div>
</BaseLayout>
