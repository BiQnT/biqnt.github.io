---
interface TimelineItem {
  title: string;
  organization: string;
  period: string;
  location?: string;
  description?: string;
}

interface Props {
  items: TimelineItem[];
  compact?: boolean;
}

const { items, compact = false } = Astro.props;
---

<div class="relative">
  <!-- Pixel-style dotted vertical line -->
  <div class="absolute left-[15px] top-0 bottom-0 w-0.5" style="background: repeating-linear-gradient(180deg, var(--color-primary) 0px, var(--color-primary) 3px, transparent 3px, transparent 6px);"></div>
  <div class="flex flex-col gap-6">
    {items.map((item) => (
      <div class="relative pl-10">
        <!-- Pixel square dot -->
        <div class="absolute left-2 top-2 w-3 h-3 bg-[var(--color-primary)]" style="image-rendering: pixelated;"></div>
        <div class:list={[
          'pixel-border rounded-none p-4 bg-[var(--color-surface-alt)] hover:border-[var(--color-primary)] transition-colors',
          compact ? 'p-3' : 'p-4'
        ]}>
          <h3 class:list={[
            'font-semibold text-[var(--color-on-surface)]',
            compact ? 'text-sm' : ''
          ]}>{item.title}</h3>
          <p class="text-[var(--color-primary)] font-medium text-sm">{item.organization}</p>
          <div class="flex items-center gap-2 mt-1 text-xs text-[var(--color-on-surface-muted)] font-mono">
            <span>{item.period}</span>
            {item.location && <span>· {item.location}</span>}
          </div>
          {item.description && (
            <p class:list={[
              'mt-2 text-[var(--color-on-surface-muted)]',
              compact ? 'text-xs' : 'text-sm'
            ]}>{item.description}</p>
          )}
        </div>
      </div>
    ))}
  </div>
</div>
